{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Opal",
  "scopeName": "source.opal",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#fstrings" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#symbols" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#macros" },
    { "include": "#annotations" },
    { "include": "#instance-variables" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.opal",
          "begin": "###",
          "end": "###"
        },
        {
          "name": "comment.line.number-sign.opal",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.double.opal",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.triple.single.opal",
          "begin": "'''",
          "end": "'''"
        },
        {
          "name": "string.quoted.double.opal",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.opal",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.opal",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.opal",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "fstrings": {
      "patterns": [
        {
          "name": "string.interpolated.opal",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.opal",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.opal",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.opal" } },
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.opal" } },
              "patterns": [{ "include": "source.opal" }]
            }
          ]
        },
        {
          "name": "string.interpolated.opal",
          "begin": "f'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.opal",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.opal",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.opal" } },
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.opal" } },
              "patterns": [{ "include": "source.opal" }]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.opal",
          "match": "\\b(if|elsif|else|then|for|while|in|do|match|case|return|break|next|try|catch|ensure|raise|end)\\b"
        },
        {
          "name": "keyword.declaration.opal",
          "match": "\\b(def|class|module|protocol|enum|model|actor|macro|event|type)\\b"
        },
        {
          "name": "keyword.other.opal",
          "match": "\\b(let|needs|requires|import|from|export|as|implements|with|where|defaults|receive|reply|send|await|emit|on|extern|parallel|async|public|private)\\b"
        },
        {
          "name": "keyword.operator.logical.opal",
          "match": "\\b(and|or|not|is)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.opal",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.opal",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.opal",
          "match": "\\bnull\\b"
        },
        {
          "name": "variable.language.self.opal",
          "match": "\\bself\\b"
        },
        {
          "name": "variable.language.self.opal",
          "match": "\\bSelf\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.opal",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.opal",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "constant.other.symbol.opal",
          "match": ":[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.opal",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.opal",
          "match": "(?<=def\\s)[a-zA-Z_\\p{L}\\p{So}\\u2200-\\u22FF\\u2190-\\u21FF][a-zA-Z0-9_\\p{L}\\p{N}\\p{So}\\p{M}\\u2200-\\u22FF\\u2190-\\u21FF]*!?"
        },
        {
          "comment": "Operator method definitions: def +(other), def ==(other), etc.",
          "name": "entity.name.function.operator.opal",
          "match": "(?<=def\\s)(\\+|\\-|\\*\\*|\\*|/|%|==|!=|<=|>=|<|>)(?=\\()"
        },
        {
          "name": "entity.name.function.call.opal",
          "match": "[a-zA-Z_\\p{L}\\p{So}][a-zA-Z0-9_\\p{L}\\p{N}\\p{So}\\p{M}]*!?(?=\\()"
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "entity.name.function.macro.opal",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.opal",
          "begin": "@\\[",
          "end": "\\]",
          "beginCaptures": { "0": { "name": "punctuation.definition.annotation.begin.opal" } },
          "endCaptures": { "0": { "name": "punctuation.definition.annotation.end.opal" } },
          "patterns": [
            {
              "name": "entity.other.attribute-name.opal",
              "match": "[a-zA-Z_][a-zA-Z0-9_]*"
            }
          ]
        }
      ]
    },
    "instance-variables": {
      "patterns": [
        {
          "name": "variable.other.member.opal",
          "match": "(?<=^|\\s)\\.[a-zA-Z_\\p{L}\\p{So}][a-zA-Z0-9_\\p{L}\\p{N}\\p{So}\\p{M}]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.opal",
          "match": "\\|>|\\.\\.\\.|\\.\\.|\\.\\?|\\?\\?|->|=>|\\+\\=|-\\=|\\*\\=|/\\=|\\*\\*|==|!=|<=|>=|[+\\-*/%<>=|&]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.opal",
          "match": "[a-zA-Z_\\p{L}\\p{So}\\u2200-\\u22FF\\u2190-\\u21FF][a-zA-Z0-9_\\p{L}\\p{N}\\p{So}\\p{M}\\u2200-\\u22FF\\u2190-\\u21FF]*!?"
        }
      ]
    }
  }
}
