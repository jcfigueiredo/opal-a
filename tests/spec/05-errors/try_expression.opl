# expect: 42 | caught: boom | Ok(5) | Error(division by zero)
r1 = try
  42
catch as e
  -1
end

r2 = try
  raise "boom"
catch as e
  f"caught: {e}"
end

def safe_div(a, b)
  try
    if b == 0
      raise "division by zero"
    end
    Ok(a / b)
  catch as e
    Error(e)
  end
end

r3 = safe_div(10, 2)
r4 = safe_div(10, 0)

print(f"{r1} | {r2} | {r3} | {r4}")
