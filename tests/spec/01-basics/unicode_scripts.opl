# expect: こんにちは世界 | Привет мир | مرحبا | 你好世界 | Ελληνικά | café

# CJK (Japanese)
def こんにちは(名前)
  f"こんにちは{名前}"
end

# Cyrillic (Russian)
def привет(имя)
  f"Привет {имя}"
end

# Arabic
def مرحبا()
  "مرحبا"
end

# CJK (Chinese)
def 你好(名字)
  f"你好{名字}"
end

# Greek
def Ελληνικά()
  "Ελληνικά"
end

# Accented Latin (French)
café = "café"

results = [
  こんにちは("世界"),
  привет("мир"),
  مرحبا(),
  你好("世界"),
  Ελληνικά(),
  café
]

print(results.join(" | "))
