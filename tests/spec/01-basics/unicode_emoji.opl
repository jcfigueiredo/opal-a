# expect: ❤️ | 🚀 launched! | 🎯 bullseye | 🌍→🌙 | 🏠=home | 7 | 🎲🎲=7

# Emoji as function names
def ❤️()
  "❤️"
end

def 🚀(payload)
  f"{payload} launched!"
end

def 🎯(target)
  f"{target} bullseye"
end

# Emoji as variable names
🌍 = "🌍"
🌙 = "🌙"

# Emoji as class name with emoji method
class 🏠House
  needs label: String

  def 🏷️()
    f"{.label}"
  end
end

🏠 = 🏠House.new(label: "home")

# Emoji in compound expressions
🎲 = 3
🎲 += 4

results = [
  ❤️(),
  🚀("🚀"),
  🎯("🎯"),
  f"{🌍}→{🌙}",
  f"🏠={🏠.🏷️()}",
  f"{🎲}",
  f"🎲🎲={🎲}"
]

print(results.join(" | "))
