# expect: Circle: area=78.5
enum Shape
  Circle(radius: Float)
  Rectangle(width: Float, height: Float)
  def describe()
    match self
      case Shape.Circle(r)
        f"Circle: area={3.14 * r * r}"
      case Shape.Rectangle(w, h)
        f"Rectangle: area={w * h}"
    end
  end
end
print(Shape.Circle(5.0).describe())
