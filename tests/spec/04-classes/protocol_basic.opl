# expect: display: Alice, age 30 | Temp: 20.0 deg | a < b: true
protocol Printable
  def to_string() -> String
  def display()
    f"display: {.to_string()}"
  end
end

protocol Comparable
  def compare_to(other) -> Int
  def less_than(other)
    .compare_to(other) < 0
  end
end

class Person implements Printable
  needs name: String
  needs age: Int
  def to_string()
    f"{.name}, age {.age}"
  end
end

class Temperature implements Printable, Comparable
  needs degrees: Float
  def to_string()
    f"{.degrees} deg"
  end
  def compare_to(other)
    if .degrees < other.degrees
      -1
    else
      if .degrees > other.degrees
        1
      else
        0
      end
    end
  end
  # Override default
  def display()
    f"Temp: {.to_string()}"
  end
end

p = Person.new(name: "Alice", age: 30)
a = Temperature.new(degrees: 20.0)
b = Temperature.new(degrees: 30.0)

print(f"{p.display()} | {a.display()} | a < b: {a.less_than(b)}")
