import Rules.{Validator, check, check_range, check_one_of}

class Registration
  needs name: String
  needs email: String
  needs age: Int
  needs role: String
end

def validate_registration(reg)
  v = Validator.new(errors: [])

  # Name checks
  check(v, reg.name.length() > 0, "name is required")
  check(v, reg.name.length() < 50, "name too long")

  # Email checks
  check(v, reg.email.contains("@"), "invalid email")

  # Age range
  check_range(v, reg.age, 18, 120, "age")

  # Role validation
  check_one_of(v, reg.role, ["admin", "user", "guest"], "role")

  v.result(reg)
end

def strict_validate(reg)
  # Macros for hard failures — raises on first error
  try
    @guard reg.name.length() > 0, "name is required"
    @guard reg.email.contains("@"), "invalid email"
    @guard reg.age >= 18, "must be 18+"
    return Ok(reg)
  catch as e
    return Error(e)
  end
end
