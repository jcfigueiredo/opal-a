# expect: OK: Alice <alice@example.com> | FAIL (3): [invalid email, age must be at least 18, role must be one of [admin, user, guest]] | STRICT: name is required
import Schema.{Registration, validate_registration, strict_validate}

# Valid registration
alice = Registration.new(
  name: "Alice",
  email: "alice@example.com",
  age: 30,
  role: "admin"
)

# Invalid registration (multiple errors)
bad = Registration.new(
  name: "Bob",
  email: "not-an-email",
  age: 15,
  role: "hacker"
)

# Invalid for strict mode (fails on first error)
empty = Registration.new(
  name: "",
  email: "x@y.com",
  age: 25,
  role: "user"
)

# Soft validation: collects all errors
r1 = match validate_registration(alice)
  case Ok(reg)
    f"OK: {reg.name} <{reg.email}>"
  case Error(errors)
    f"FAIL ({errors.length()}): {errors}"
end

r2 = match validate_registration(bad)
  case Ok(reg)
    f"OK: {reg.name}"
  case Error(errors)
    f"FAIL ({errors.length()}): {errors}"
end

# Strict validation: fails fast with macro guard
r3 = match strict_validate(empty)
  case Ok(reg)
    f"OK: {reg.name}"
  case Error(msg)
    msg
end

print(f"{r1} | {r2} | STRICT: {r3}")
