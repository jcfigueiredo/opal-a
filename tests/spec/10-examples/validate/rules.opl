macro guard(condition, message)
  ast
    if not ($condition)
      raise $message
    end
  end
end

class Validator
  needs errors: List

  def add_error(msg)
    .errors = .errors.push(msg)
  end

  def is_valid()
    .errors.length() == 0
  end

  def error_count()
    .errors.length()
  end

  def result(value)
    if .is_valid()
      Ok(value)
    else
      Error(.errors)
    end
  end
end

def check(validator, condition, message)
  if not condition
    validator.add_error(message)
  end
end

def check_range(validator, value, min, max, label)
  if value < min
    validator.add_error(f"{label} must be at least {min}")
  end
  if value > max
    validator.add_error(f"{label} must be at most {max}")
  end
end

def check_one_of(validator, value, allowed, label)
  matches = allowed.filter(|a| a == value)
  if matches.length() == 0
    validator.add_error(f"{label} must be one of {allowed}")
  end
end
