# Protocols for the shapes domain

protocol Describable
  # Required: every shape must describe itself
  def describe() -> String

  # Default: summary wraps describe with brackets
  def summary()
    f"[{.describe()}]"
  end
end

protocol Measurable
  # Required
  def area() -> Float
  def perimeter() -> Float

  # Default: compare by area
  def larger_than(other)
    .area() > other.area()
  end

  # Default: format measurement
  def measurements()
    f"area={.area()}, perimeter={.perimeter()}"
  end
end
