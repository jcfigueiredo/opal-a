import Protocols.{Describable, Measurable}

class Circle implements Describable, Measurable
  needs radius: Float

  def describe()
    f"Circle(r={.radius})"
  end

  def area()
    3.14159 * .radius * .radius
  end

  def perimeter()
    2.0 * 3.14159 * .radius
  end
end

class Rectangle implements Describable, Measurable
  needs width: Float
  needs height: Float

  def describe()
    f"Rect({.width}x{.height})"
  end

  def area()
    .width * .height
  end

  def perimeter()
    2.0 * (.width + .height)
  end

  # Override default summary
  def summary()
    f"[{.describe()} area={.area()}]"
  end
end

class Triangle implements Describable, Measurable
  needs base: Float
  needs height: Float
  needs side_a: Float
  needs side_b: Float

  def describe()
    f"Triangle(b={.base}, h={.height})"
  end

  def area()
    0.5 * .base * .height
  end

  def perimeter()
    .base + .side_a + .side_b
  end
end

def biggest(shapes)
  result = shapes.get(0)
  i = 1
  while i < shapes.length()
    candidate = shapes.get(i)
    if candidate.larger_than(result)
      result = candidate
    end
    i = i + 1
  end
  result
end
