# expect: 5 passed, 0 failed
import Container.{Container, new_container}
import Services.{Logger, Database, Cache, UserService, OrderService}

macro assert(condition, message)
  ast
    if not ($condition)
      raise f"AssertFailed: {$message}"
    end
  end
end

macro assert_eq(actual, expected, label)
  ast
    @assert $actual == $expected, f"{$label}: expected {$expected}, got {$actual}"
  end
end

results = []

# Test 1: Basic registration and resolution
t1 = try
  c = new_container()
  c.register("logger", || Logger.new(prefix: "TEST"))
  log = c.resolve("logger")
  @assert_eq log.prefix, "TEST", "logger prefix"
  "pass"
catch as e
  f"fail: {e}"
end
results = results.push(t1)

# Test 2: Singleton caching
t2 = try
  c = new_container()
  count = 0
  c.register("logger") do
    count = count + 1
    Logger.new(prefix: f"v{count}")
  end
  l1 = c.resolve("logger")
  l2 = c.resolve("logger")
  @assert_eq l1.prefix, l2.prefix, "same instance"
  "pass"
catch as e
  f"fail: {e}"
end
results = results.push(t2)

# Test 3: Dependency chain
t3 = try
  c = new_container()
  c.register("logger", || Logger.new(prefix: "CHAIN"))
  c.register("database", || Database.new(host: "test.db", logger: c.resolve("logger")))
  db = c.resolve("database")
  result = db.query("SELECT 1")
  @assert result.contains("CHAIN"), "logger propagated"
  @assert result.contains("test.db"), "host propagated"
  "pass"
catch as e
  f"fail: {e}"
end
results = results.push(t3)

# Test 4: Missing dependency raises error
t4 = try
  c = new_container()
  c.resolve("nonexistent")
  "fail: should have raised"
catch as e
  if e.contains("no factory registered")
    "pass"
  else
    f"fail: wrong error: {e}"
  end
end
results = results.push(t4)

# Test 5: Deep dependency graph (5 services)
t5 = try
  c = new_container()
  c.register("logger", || Logger.new(prefix: "DEEP"))
  c.register("database", || Database.new(host: "deep.db", logger: c.resolve("logger")))
  c.register("cache", || Cache.new(ttl: 60, logger: c.resolve("logger")))
  c.register("user_service") do
    UserService.new(db: c.resolve("database"), cache: c.resolve("cache"), logger: c.resolve("logger"))
  end
  c.register("order_service") do
    OrderService.new(db: c.resolve("database"), users: c.resolve("user_service"), logger: c.resolve("logger"))
  end
  orders = c.resolve("order_service")
  result = orders.place(1, "Widget")
  @assert result.contains("DEEP"), "deep logger"
  @assert_eq c.registered().length(), 5, "service count"
  "pass"
catch as e
  f"fail: {e}"
end
results = results.push(t5)

# Report
passed = results.filter(|r| r == "pass").length()
failed = results.length() - passed
print(f"{passed} passed, {failed} failed")
