# Domain services with dependency declarations via needs

class Logger
  needs prefix: String

  def info(msg)
    f"[{.prefix}] {msg}"
  end
end

class Database
  needs host: String
  needs logger: Logger

  def query(sql)
    .logger.info(f"DB({.host}): {sql}")
  end
end

class Cache
  needs ttl: Int
  needs logger: Logger

  def get(key)
    .logger.info(f"cache miss: {key}")
  end
end

class UserService
  needs db: Database
  needs cache: Cache
  needs logger: Logger

  def find(id)
    .cache.get(f"user:{id}")
    .db.query(f"SELECT * FROM users WHERE id = {id}")
  end
end

class OrderService
  needs db: Database
  needs users: UserService
  needs logger: Logger

  def place(user_id, product)
    .users.find(user_id)
    .db.query(f"INSERT INTO orders (user_id, product) VALUES ({user_id}, '{product}')")
    .logger.info(f"order placed: {product} for user {user_id}")
  end
end
