# expect: [APP] order placed: Laptop for user 1 | services: 5 | singleton: true
import Container.{new_container}
import Services.{Logger, Database, Cache, UserService, OrderService}

# Create container
c = new_container()

# Register factories — closures capture `c` for recursive resolution
c.register("logger", || Logger.new(prefix: "APP"))
c.register("database", || Database.new(host: "db.local", logger: c.resolve("logger")))
c.register("cache", || Cache.new(ttl: 300, logger: c.resolve("logger")))
c.register("user_service") do
  UserService.new(
    db: c.resolve("database"),
    cache: c.resolve("cache"),
    logger: c.resolve("logger")
  )
end
c.register("order_service") do
  OrderService.new(
    db: c.resolve("database"),
    users: c.resolve("user_service"),
    logger: c.resolve("logger")
  )
end

# Resolve top-level service — entire dependency graph resolves recursively
orders = c.resolve("order_service")
result = orders.place(1, "Laptop")

# Verify singleton behavior — same logger instance everywhere
log1 = c.resolve("logger")
log2 = c.resolve("logger")

# Count registered services
services = c.registered()

print(f"{result} | services: {services.length()} | singleton: {log1.prefix == log2.prefix}")
