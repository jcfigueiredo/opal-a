# EventBus actor + @emit/@on macros
# Demonstrates self-hosting: language features as macros, not keywords

actor EventBus
  def init()
    .handlers = []
    .log = []
  end

  receive
    case Ok(handler)
      .handlers = .handlers.push(handler)
      reply Ok(:registered)
    case Some(payload)
      .log = .log.push(payload)
      for h in .handlers
        h(payload)
      end
      reply Ok(:dispatched)
    case :log
      reply .log
    case :count
      reply .handlers.length()
  end
end

# Self-hosted macros: emit and on are macros, not parser keywords
macro emit(bus, payload)
  ast
    await $bus.send(Some($payload))
  end
end

macro on(bus, handler)
  ast
    await $bus.send(Ok($handler))
  end
end
