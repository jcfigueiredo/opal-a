# expect: 3 passed, 0 failed
import Eventbus.{EventBus}
import Testing

# --- Test 1: Events get logged ---
bus = EventBus.new()

handler = |msg| msg
@on bus, handler

@emit bus, "signup"
@emit bus, "login"

log = await bus.send(:log)

t1 = "fail"
try
  @assert_eq log.length(), 2, "log count"
  t1 = "pass"
catch as e
  t1 = e
end

# --- Test 2: Handler count tracks registrations ---
bus2 = EventBus.new()
h1 = |msg| msg
h2 = |msg| msg
@on bus2, h1
@on bus2, h2

handler_count = await bus2.send(:count)

t2 = "fail"
try
  @assert_eq handler_count, 2, "handler count"
  t2 = "pass"
catch as e
  t2 = e
end

# --- Test 3: Nested macro assert catches mismatch ---
t3 = "fail"
try
  @assert_eq 1 + 1, 2, "basic math"
  @assert_eq "hello".length(), 5, "string length"
  t3 = "pass"
catch as e
  t3 = e
end

# --- Report ---
results = [t1, t2, t3]
passed = results.filter(|r| r == "pass").length()
failed = results.length() - passed
print(f"{passed} passed, {failed} failed")
