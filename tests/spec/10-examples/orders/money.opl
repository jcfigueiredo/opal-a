class Money
  needs amount: Float
  needs currency: String

  def add(other)
    requires .currency == other.currency, "currency mismatch"
    Money.new(amount: .amount + other.amount, currency: .currency)
  end

  def multiply(factor)
    Money.new(amount: .amount * factor, currency: .currency)
  end

  def display()
    f"{.currency} {.amount}"
  end
end

def zero_usd()
  Money.new(amount: 0.0, currency: "USD")
end
