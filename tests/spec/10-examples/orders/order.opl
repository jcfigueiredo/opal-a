import Catalog.{Product}

class OrderLine
  needs product: Product
  needs quantity: Int

  def line_total()
    .quantity * .product.price
  end
end

class Order
  needs id: String
  needs lines: List
  needs status: Symbol
  needs discount: Float

  def subtotal()
    .lines.reduce(0.0) do |acc, line|
      acc + line.line_total()
    end
  end

  def total()
    sub = .subtotal()
    sub - (sub * .discount)
  end

  def summary()
    f"Order({.id}): {.lines.length()} items, {.status}"
  end
end

def validate_order(order)
  if order.lines.length() == 0
    return Error("order must have at least one line")
  end

  negatives = order.lines.filter(|l| l.quantity < 1)
  if negatives.length() > 0
    return Error("all quantities must be positive")
  end

  Ok(order)
end

def apply_status(order, new_status)
  current = order.status

  allowed = match current
    case :draft
      [:confirmed, :cancelled]
    case :confirmed
      [:shipped, :cancelled]
    case :shipped
      [:delivered]
    case _
      []
  end

  valid = allowed.filter(|s| s == new_status)
  if valid.length() == 0
    return Error(f"cannot transition from {current} to {new_status}")
  end

  Ok(Order.new(
    id: order.id,
    lines: order.lines,
    status: new_status,
    discount: order.discount
  ))
end
