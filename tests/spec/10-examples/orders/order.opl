class OrderLine
  needs product: String
  needs quantity: Int
  needs unit_price: Float

  def get_product()
    .product
  end

  def get_quantity()
    .quantity
  end

  def get_unit_price()
    .unit_price
  end

  def line_total()
    .quantity * .unit_price
  end
end

class Order
  needs id: String
  needs lines: List
  needs status: Symbol
  needs discount: Float

  def get_id()
    .id
  end

  def get_lines()
    .lines
  end

  def get_status()
    .status
  end

  def get_discount()
    .discount
  end

  def subtotal()
    .lines.reduce(0.0) do |acc, line|
      acc + line.line_total()
    end
  end

  def total()
    sub = .subtotal()
    sub - (sub * .discount)
  end

  def line_count()
    .lines.length()
  end

  def summary()
    f"Order({.id}): {.lines.length()} items, {.status}"
  end
end

def validate_order(order)
  lines = order.get_lines()
  if lines.length() == 0
    return Error("order must have at least one line")
  end

  negatives = lines.filter(|l| l.get_quantity() < 1)
  if negatives.length() > 0
    return Error("all quantities must be positive")
  end

  Ok(order)
end

def apply_status(order, new_status)
  current = order.get_status()

  allowed = match current
    case :draft
      [:confirmed, :cancelled]
    case :confirmed
      [:shipped, :cancelled]
    case :shipped
      [:delivered]
    case _
      []
  end

  valid = allowed.filter(|s| s == new_status)
  if valid.length() == 0
    return Error(f"cannot transition from {current} to {new_status}")
  end

  Ok(Order.new(
    id: order.get_id(),
    lines: order.get_lines(),
    status: new_status,
    discount: order.get_discount()
  ))
end
