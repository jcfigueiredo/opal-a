def bulk_discount(lines)
  total_qty = lines.reduce(0) do |acc, l|
    acc + l.get_quantity()
  end

  if total_qty >= 10
    Some(0.1)
  else
    if total_qty >= 5
      Some(0.05)
    else
      None
    end
  end
end

def premium_items(lines)
  lines.filter(|l| l.get_unit_price() > 50.0)
end

def format_line(line)
  f"  {line.get_product()} x{line.get_quantity()} @ {line.get_unit_price()}"
end

def format_report(order)
  header = order.summary()
  line_details = order.get_lines().map(|l| format_line(l))
  discount_pct = order.get_discount() * 100.0
  f"{header} | discount: {discount_pct}% | total: {order.total()}"
end
