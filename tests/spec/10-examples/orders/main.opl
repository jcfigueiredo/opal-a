# expect: Order(ORD-1): 3 items, :confirmed | discount: 10.0% | total: 270.0
import Order.{OrderLine, Order, validate_order, apply_status}
import Pricing.{bulk_discount, premium_items, format_report}

# Build order lines
lines = [
  OrderLine.new(product: "Widget", quantity: 5, unit_price: 25.0),
  OrderLine.new(product: "Gadget", quantity: 3, unit_price: 50.0),
  OrderLine.new(product: "Gizmo", quantity: 2, unit_price: 12.5)
]

# Determine discount using Option type
discount = match bulk_discount(lines)
  case Some(d)
    d
  case None
    0.0
end

# Create draft order
draft = Order.new(id: "ORD-1", lines: lines, status: :draft, discount: discount)

# Validate and transition through states
result = match validate_order(draft)
  case Ok(valid_order)
    apply_status(valid_order, :confirmed)
  case Error(msg)
    Error(f"validation failed: {msg}")
end

# Handle the final result
match result
  case Ok(confirmed)
    print(format_report(confirmed))
  case Error(msg)
    print(f"Failed: {msg}")
end
