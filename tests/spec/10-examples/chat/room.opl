actor Room
  def init()
    .members = []
    .history = []
  end

  receive
    case Ok(user)
      # Join: add user if not already a member
      already = .members.filter(|m| m == user)
      if already.length() > 0
        reply Error(f"{user} already in room")
      else
        .members = .members.push(user)
        reply Ok(f"{user} joined")
      end
    case Some(entry)
      # Post: add message to history
      .history = .history.push(entry)
      reply Ok(:posted)
    case :members
      reply .members
    case :history
      reply .history
    case :count
      reply .history.length()
    case _
      reply Error(:unknown)
  end
end

def post(room, user, text)
  members = await room.send(:members)
  is_member = members.filter(|m| m == user)
  if is_member.length() == 0
    return Error(f"{user} is not a member")
  end
  await room.send(Some(f"{user}: {text}"))
end

def format_history(room)
  history = await room.send(:history)
  if history.length() == 0
    return "(empty)"
  end
  history.reduce("") do |acc, msg|
    if acc.length() == 0
      msg
    else
      f"{acc} | {msg}"
    end
  end
end
