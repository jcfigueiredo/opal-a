# expect: [general] Alice: Hello! | Bob: Hi Alice! | Alice: Anyone here? (3 msgs) | Events: 7 | Last: [random] Bob leaves
import Room.{Room, post, format_history}
import Logger.{Logger, log_entry, summarize}

# Create actors
general = Room.new()
random = Room.new()
logger = Logger.new()

# Join rooms
r1 = await general.send(Ok("Alice"))
log_entry(logger, "general", "Alice joins")

r2 = await general.send(Ok("Bob"))
log_entry(logger, "general", "Bob joins")

r3 = await random.send(Ok("Alice"))
log_entry(logger, "random", "Alice joins")

r4 = await random.send(Ok("Bob"))
log_entry(logger, "random", "Bob joins")

# Try duplicate join
dup = await general.send(Ok("Alice"))
match dup
  case Error(msg)
    log_entry(logger, "general", f"rejected: {msg}")
  case Ok(_)
    log_entry(logger, "general", "unexpected success")
end

# Post messages
post(general, "Alice", "Hello!")
post(general, "Bob", "Hi Alice!")
post(general, "Alice", "Anyone here?")

# Try posting as non-member
bad = post(random, "Eve", "Sneaking in")
match bad
  case Error(msg)
    log_entry(logger, "random", f"blocked: {msg}")
  case _
    log_entry(logger, "random", "should not happen")
end

log_entry(logger, "random", "Bob leaves")

# Report
gen_history = format_history(general)
gen_count = await general.send(:count)
summary = summarize(logger)

print(f"[general] {gen_history} ({gen_count} msgs) | {summary}")
