actor Logger
  def init()
    .logs = []
  end

  receive
    case Ok(entry)
      .logs = .logs.push(entry)
      reply Ok(:logged)
    case :dump
      reply .logs
    case :count
      reply .logs.length()
    case _
      reply Error(:unknown)
  end
end

def log_entry(logger, room_name, entry)
  await logger.send(Ok(f"[{room_name}] {entry}"))
end

def summarize(logger)
  count = await logger.send(:count)
  logs = await logger.send(:dump)

  last = if count > 0
    logs.get(count - 1)
  else
    "(none)"
  end

  f"Events: {count} | Last: {last}"
end
