# expect: Pipeline: 6 values, avg 34
import Transforms

raw = [10, 25, 30, 45, 50, 65, 80, 90]

normalized = Transforms.normalize(raw, 10, 90)

filtered = normalized.filter(|x| x <= 80)

stats = Transforms.summarize(filtered)
count_key = "count"
avg_key = "average"
print(f"Pipeline: {stats.get(count_key)} values, avg {stats.get(avg_key)}")
