# expect: ok | fail: not big enough
macro guard(cond, msg)
  ast
    if not ($cond)
      raise $msg
    end
  end
end

macro safe_block(body)
  ast
    try
      $body
    catch as e
      raise e
    end
  end
end

r1 = "none"
r2 = "none"

try
  @safe_block
    @guard true, "should pass"
  end
  r1 = "ok"
catch as e
  r1 = f"fail: {e}"
end

try
  @safe_block
    @guard false, "not big enough"
  end
  r2 = "ok"
catch as e
  r2 = f"fail: {e}"
end

print(f"{r1} | {r2}")
