# expect: Ok(5) | Error(must be positive)
macro check(condition, message)
  ast
    if not ($condition)
      raise $message
    end
  end
end

macro validated(condition, message)
  ast
    @check $condition, $message
  end
end

def validate(x)
  try
    @validated x > 0, "must be positive"
    @validated x < 100, "must be under 100"
    return Ok(x)
  catch as e
    return Error(e)
  end
end

r1 = validate(5)
r2 = validate(-1)
print(f"{r1} | {r2}")
