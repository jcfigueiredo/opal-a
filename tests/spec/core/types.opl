# expect: Int | true | true | String | false
# Opal's type system described in Opal itself

enum OpalType
  IntType
  FloatType
  StringType
  BoolType
  NullType
  ListType
  DictType
  FnType
end

def opal_typeof(value)
  match typeof(value).name
    case "Int"
      OpalType.IntType
    case "Float"
      OpalType.FloatType
    case "String"
      OpalType.StringType
    case "Bool"
      OpalType.BoolType
    case "Null"
      OpalType.NullType
    case "List"
      OpalType.ListType
    case "Dict"
      OpalType.DictType
    case _
      OpalType.FnType
  end
end

def is_numeric(t)
  match t
    case OpalType.IntType
      true
    case OpalType.FloatType
      true
    case _
      false
  end
end

t1 = typeof(42).name
t2 = is_numeric(opal_typeof(42))
t3 = is_numeric(opal_typeof(3.14))
t4 = typeof("hello").name
t5 = is_numeric(opal_typeof("hello"))
print(f"{t1} | {t2} | {t3} | {t4} | {t5}")
