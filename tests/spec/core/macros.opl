# expect: 15 | unless works
# Opal metaprogramming: AST quoting and eval

# Macro: unless
macro unless(condition, body)
  ast
    if not $condition
      $body
    end
  end
end

# AST evaluation in isolated scope
code = ast
  x = 5
  x * 3
end
result = eval(code)

parts = [f"{result}", "unless works"]

@unless true
  parts = parts.push("this should not appear")
end

print(parts.join(" | "))
