# expect: рҹҹў | жҳҘ | вҶ’ East

# Emoji enum
enum рҹҡҰSignal
  рҹҹў
  рҹҹЎ
  рҹ”ҙ
end

# CJK enum
enum еӯЈзҜҖ
  жҳҘ
  еӨҸ
  з§Ӣ
  еҶ¬
end

# Standard enum with Unicode method
enum Direction
  North
  South
  East
  West

  def вҶ’()
    match self
      case Direction.East
        "вҶ’ East"
      case Direction.West
        "вҶҗ West"
      case Direction.North
        "вҶ‘ North"
      case Direction.South
        "вҶ“ South"
    end
  end
end

light = рҹҡҰSignal.рҹҹў
season = еӯЈзҜҖ.жҳҘ
dir = Direction.East

# Match emoji enum
light_str = match light
  case рҹҡҰSignal.рҹҹў
    "рҹҹў"
  case рҹҡҰSignal.рҹҹЎ
    "рҹҹЎ"
  case _
    "рҹ”ҙ"
end

# Match CJK enum
season_str = match season
  case еӯЈзҜҖ.жҳҘ
    "жҳҘ"
  case еӯЈзҜҖ.еӨҸ
    "еӨҸ"
  case _
    "?"
end

results = [light_str, season_str, dir.вҶ’()]

print(results.join(" | "))
