# expect: Entity #1 active | Player #2 active hp=100 | Mage #3 active hp=100 mana=50 | true | true

# Deep init() super() chain + to_string() + is operator + Type() shorthand
class Entity
  def init()
    .id = 1
    .status = "active"
  end

  def to_string()
    f"Entity #{.id} {.status}"
  end
end

class Player < Entity
  needs name: String

  def init()
    super()
    .id = 2
    .hp = 100
  end

  def to_string()
    f"Player #{.id} {.status} hp={.hp}"
  end
end

class Mage < Player
  needs school: String

  def init()
    super()
    .id = 3
    .mana = 50
  end

  def to_string()
    f"Mage #{.id} {.status} hp={.hp} mana={.mana}"
  end
end

e = Entity.new()
p = Player(name: "Hero")
m = Mage(name: "Gandalf", school: "Fire")

results = [
  f"{e}",
  f"{p}",
  f"{m}",
  f"{m is Player}",
  f"{m is Entity}"
]

print(results.join(" | "))
