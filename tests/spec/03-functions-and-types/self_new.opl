# expect: 7 | (4.0, 6.0) | $15.5 | 6 | true | false

# Basic Self.new() in operator def
class Rating
  needs stars: Int

  def +(other)
    Self.new(stars: .stars + other.stars)
  end
end

r = Rating.new(stars: 3) + Rating.new(stars: 4)

# Self.new() in multiple operators
class Vec2
  needs x: Float
  needs y: Float

  def +(other)
    Self.new(x: .x + other.x, y: .y + other.y)
  end

  def -(other)
    Self.new(x: .x - other.x, y: .y - other.y)
  end

  def *(scalar)
    Self.new(x: .x * scalar, y: .y * scalar)
  end

  def ==(other)
    .x == other.x and .y == other.y
  end
end

a = Vec2.new(x: 1.0, y: 2.0)
b = Vec2.new(x: 3.0, y: 4.0)
sum = a + b

# Self.new() in regular method
class Currency
  needs amount: Float
  needs symbol: String

  def +(other)
    Self.new(amount: .amount + other.amount, symbol: .symbol)
  end

  def display()
    f"{.symbol}{.amount}"
  end

  def double()
    Self.new(amount: .amount * 2, symbol: .symbol)
  end
end

price = Currency.new(amount: 10.0, symbol: "$") + Currency.new(amount: 5.50, symbol: "$")

# Self.new() chained
class Counter
  needs n: Int

  def +(other)
    Self.new(n: .n + other.n)
  end

  def increment()
    Self.new(n: .n + 1)
  end
end

c = Counter.new(n: 1).increment().increment().increment() + Counter.new(n: 2)

# Self.new() preserves class identity
class Point
  needs x: Int
  needs y: Int

  def +(other)
    Self.new(x: .x + other.x, y: .y + other.y)
  end

  def ==(other)
    .x == other.x and .y == other.y
  end
end

p = Point.new(x: 1, y: 2) + Point.new(x: 3, y: 4)
eq = p == Point.new(x: 4, y: 6)
neq = p == Point.new(x: 0, y: 0)

results = [
  f"{r.stars}",
  f"({sum.x}, {sum.y})",
  price.display(),
  f"{c.n}",
  f"{eq}",
  f"{neq}"
]

print(results.join(" | "))
